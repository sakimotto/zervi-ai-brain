# Database
POSTGRES_URI=postgresql+asyncpg://user:password@zervi-postgresql:5432/ai_brain
PGVECTOR_URI=postgresql+asyncpg://user:password@zervi-postgresql:5432/ai_brain

# Embeddings (OpenAI-compatible: OpenAI, OpenRouter, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
# Output token budget. DeepSeek v4-pro has a huge context window; for an ERP
# assistant, truncated JSON/tool calls are far more expensive than tokens.
MAX_TOKENS_CHAT=4096
MAX_TOKENS_SUGGEST=512
# Retries on transient DeepSeek errors (502/503/504/429/timeouts)
DEEPSEEK_RETRY_ATTEMPTS=3
DEEPSEEK_RETRY_BACKOFF=1.0

# Security
AI_ASSISTANT_SECRET=change-me-in-production
