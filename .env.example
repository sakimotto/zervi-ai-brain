# Database
POSTGRES_URI=postgresql+asyncpg://user:password@zervi-postgresql:5432/ai_brain
PGVECTOR_URI=postgresql+asyncpg://user:password@zervi-postgresql:5432/ai_brain

# Embeddings (OpenAI-compatible: OpenAI, OpenRouter, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
